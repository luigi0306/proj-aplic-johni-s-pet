{
  "name": "petshop-backend",
  "version": "1.0.0",
  "description": "Backend API for Petshop using Node.js, Express, and PostgreSQL",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:setup": "ts-node scripts/setup_db.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
